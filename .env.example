# Supabase project credentials (Project Settings → API).
# If left empty the app still works, falling back to browser localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 4-digit PIN gate. Generate a hash with:  npm run pin:hash -- 1234
# If left empty, the default PIN is 1234.
# NOTE: this is a casual privacy gate, not real security — see README.
VITE_PIN_HASH=
VITE_PIN_SALT=atlas-pin-v1
